# Example secrets file for NYC01
#
# IMPORTANT: This is an EXAMPLE only. Never commit unencrypted secrets!
#
# To use:
# 1. Copy this file: cp secrets.yaml.example secrets.yaml
# 2. Fill in real values
# 3. Encrypt with SOPS: sops --encrypt secrets.yaml > secrets.enc.yaml
# 4. Delete plaintext: rm secrets.yaml
# 5. Commit only secrets.enc.yaml

# TACACS+ shared secret for legacy clients
tacacs_shared_secret: "CHANGE-ME-super-secret-key-12345"

# LDAP bind password
ldap_bind_password: "CHANGE-ME-ldap-service-account-password"

# TLS certificates (if not using EST auto-provisioning)
tls_server_cert: |
  -----BEGIN CERTIFICATE-----
  MIIDXTCCAkWgAwIBAgIJAKZ...
  -----END CERTIFICATE-----

tls_server_key: |
  -----BEGIN PRIVATE KEY-----
  MIIEvQIBADANBgkqhkiG9w0...
  -----END PRIVATE KEY-----

# API TLS certificates (for direct TLS mode, not reverse proxy)
api_tls_cert: |
  -----BEGIN CERTIFICATE-----
  MIIDXTCCAkWgAwIBAgIJAKZ...
  -----END CERTIFICATE-----

api_tls_key: |
  -----BEGIN PRIVATE KEY-----
  MIIEvQIBADANBgkqhkiG9w0...
  -----END PRIVATE KEY-----

# OpenBao authentication (if using OpenBao for secrets)
openbao_role_id: "CHANGE-ME-role-id"
openbao_secret_id: "CHANGE-ME-secret-id"

# EST provisioning (if using EST)
est_username: "CHANGE-ME-est-bootstrap-user"
est_password: "CHANGE-ME-est-bootstrap-password"

# Emergency break-glass credentials
emergency_admin_password: "CHANGE-ME-argon2-hashed-password"

# Metadata (not encrypted)
_metadata:
  location: "NYC01"
  rotation_date: "2026-01-18"
  next_rotation: "2026-04-18"
  rotated_by: "security-team@example.com"
